# SurrealDB connection
SURREAL_ENDPOINT=http://127.0.0.1:8000
SURREAL_NAMESPACE=auth
SURREAL_DATABASE=main
SURREAL_USER=root
SURREAL_PASS=root

# API
BIND_ADDR=127.0.0.1:3000
JWT_SECRET=your_jwt_secret
# JWT_PUBLIC_KEY_PEM=/path/to/public.pem
# JWT_SECRET should match Rainbow-Auth's JWT_SECRET (HS256)
# set to 0/false/off to skip CSRF checks during local dev
ENFORCE_CSRF=1

# CORS
CORS_ORIGIN=http://127.0.0.1:8080

# Rainbow-Auth
RAINBOW_AUTH_BASE_URL=http://127.0.0.1:8080

# Uploads
UPLOAD_DIR=uploads
UPLOAD_BASE_URL=/uploads
MAX_UPLOAD_MB=50
# comma-separated lower-case mime list, e.g. image/png,image/jpeg
ALLOWED_MIME=
